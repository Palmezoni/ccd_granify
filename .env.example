# ─── BANCO DE DADOS ───────────────────────────────────────────────────────────
DATABASE_URL="postgresql://granify:granify@localhost:5433/granify"

# ─── AUTH (JWT) ───────────────────────────────────────────────────────────────
JWT_SECRET="gere-com-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI: https://granify.net/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── MICROSOFT OAUTH ──────────────────────────────────────────────────────────
# Portal: https://portal.azure.com → App registrations → New registration
# Account types: "Accounts in any organizational directory and personal Microsoft accounts"
# Redirect URI: https://granify.net/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# ─── APPLE SIGN IN ────────────────────────────────────────────────────────────
# Developer: https://developer.apple.com → Certificates, Identifiers & Profiles
# 1. Criar App ID com "Sign In with Apple" capability
# 2. Criar Services ID (ex: net.granify.signin) — este é o APPLE_CLIENT_ID
# 3. Configurar Domains: granify.net | Return URL: https://granify.net/api/auth/callback/apple
# 4. Criar Key com "Sign In with Apple" → baixar .p8 → conteúdo vai em APPLE_PRIVATE_KEY
# Nota: cole o conteúdo do .p8 com \n substituindo quebras de linha reais
APPLE_CLIENT_ID="net.granify.signin"
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""

# ─── E-MAIL (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@granify.com.br"

# ─── CAKTO (pagamentos) ───────────────────────────────────────────────────────
CAKTO_WEBHOOK_SECRET=""

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Granify"

# ─── STRIPE (pagamentos) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_MONTHLY="price_..."
STRIPE_PRICE_SEMIANNUAL="price_..."
STRIPE_PRICE_ANNUAL="price_..."
